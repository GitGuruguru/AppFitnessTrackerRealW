<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppFitnessTrackerReal.Dashbord"
             BackgroundColor="#F2F5FA"
             Title="">
    <ScrollView>
        <Grid HorizontalOptions="Center"
              VerticalOptions="Start"
              WidthRequest="420"
              MaximumWidthRequest="420"
              Padding="18,20,18,40">
            <VerticalStackLayout Spacing="18">
                <Grid ColumnDefinitions="Auto,* ,Auto"
                      VerticalOptions="Center">
                    <Border Grid.Column="0"
                            BackgroundColor="#2B6DFF"
                            StrokeThickness="0"
                            Padding="12"
                            StrokeShape="RoundRectangle 22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAccountTapped" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="34,Auto"
                              ColumnSpacing="10">
                            <Grid WidthRequest="34"
                                  HeightRequest="34">
                                <Ellipse WidthRequest="13"
                                         HeightRequest="13"
                                         Fill="White"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Start"
                                         Margin="0,3,0,0" />
                                <Ellipse WidthRequest="20"
                                         HeightRequest="12"
                                         Fill="White"
                                         HorizontalOptions="Center"
                                         VerticalOptions="End"
                                         Margin="0,0,0,2" />
                            </Grid>
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="0"
                                                 VerticalOptions="Center">
                                <Label Text="Account"
                                       FontFamily="OpenSansRegular"
                                       FontSize="12"
                                       TextColor="#D8E5FF" />
                                <Label x:Name="UserNameLabel"
                                       Text="Guest"
                                       FontFamily="MuseoModernoMedium"
                                       FontSize="15"
                                       TextColor="White" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <Button Grid.Column="2"
                            Text="Log out"
                            Clicked="OnLogoutClicked"
                            FontFamily="OpenSansSemibold"
                            BackgroundColor="#111827"
                            TextColor="White"
                            CornerRadius="18"
                            Padding="18,12" />
                </Grid>

                <Border BackgroundColor="#0F172A"
                        StrokeThickness="0"
                        Padding="22"
                        StrokeShape="RoundRectangle 28">
                    <VerticalStackLayout Spacing="18">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Nutrition balance"
                                   FontFamily="MuseoModernoBold"
                                   FontSize="24"
                                   TextColor="White" />
                            <Label Text="Your dish list grows the macro ring in real time."
                                   FontFamily="OpenSansRegular"
                                   FontSize="13"
                                   TextColor="#9FB0CF" />
                        </VerticalStackLayout>

                        <Grid HorizontalOptions="Center"
                              WidthRequest="270"
                              HeightRequest="270">
                            <GraphicsView x:Name="MacroRingView"
                                          HeightRequest="270"
                                          WidthRequest="270" />
                            <VerticalStackLayout HorizontalOptions="Center"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="Daily mix"
                                       HorizontalTextAlignment="Center"
                                       FontFamily="OpenSansRegular"
                                       FontSize="13"
                                       TextColor="#A8B6D6" />
                                <Label x:Name="MacroTotalLabel"
                                       Text="0 g"
                                       HorizontalTextAlignment="Center"
                                       FontFamily="MuseoModernoBold"
                                       FontSize="32"
                                       TextColor="White" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*"
                              ColumnSpacing="10">
                            <Border BackgroundColor="#16233C"
                                    StrokeThickness="0"
                                    Padding="12"
                                    StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="Protein"
                                           FontFamily="OpenSansRegular"
                                           FontSize="12"
                                           TextColor="#9FB0CF" />
                                    <Label x:Name="ProteinValueLabel"
                                           Text="0 g"
                                           FontFamily="MuseoModernoMedium"
                                           FontSize="20"
                                           TextColor="#78D7B4" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1"
                                    BackgroundColor="#16233C"
                                    StrokeThickness="0"
                                    Padding="12"
                                    StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="Carbs"
                                           FontFamily="OpenSansRegular"
                                           FontSize="12"
                                           TextColor="#9FB0CF" />
                                    <Label x:Name="CarbsValueLabel"
                                           Text="0 g"
                                           FontFamily="MuseoModernoMedium"
                                           FontSize="20"
                                           TextColor="#6AA7FF" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="2"
                                    BackgroundColor="#16233C"
                                    StrokeThickness="0"
                                    Padding="12"
                                    StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="Fats"
                                           FontFamily="OpenSansRegular"
                                           FontSize="12"
                                           TextColor="#9FB0CF" />
                                    <Label x:Name="FatsValueLabel"
                                           Text="0 g"
                                           FontFamily="MuseoModernoMedium"
                                           FontSize="20"
                                           TextColor="#FFB45C" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White"
                        Stroke="#D8E2F0"
                        StrokeThickness="1"
                        Padding="18"
                        StrokeShape="RoundRectangle 24">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Dish manager"
                                       FontFamily="MuseoModernoBold"
                                       FontSize="22"
                                       TextColor="#111827" />
                                <Label Text="Add, edit, or remove dishes without leaving the dashboard."
                                       FontFamily="OpenSansRegular"
                                       FontSize="13"
                                       TextColor="#667085" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1"
                                   Text="Tap a dish to edit"
                                   VerticalOptions="Center"
                                   FontFamily="OpenSansRegular"
                                   FontSize="12"
                                   TextColor="#98A2B3" />
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*"
                              ColumnSpacing="10">
                            <Button Grid.Column="0"
                                    Text="Add"
                                    Clicked="OnAddDishClicked"
                                    FontFamily="OpenSansSemibold"
                                    BackgroundColor="#2B6DFF"
                                    TextColor="White"
                                    CornerRadius="18" />
                            <Button Grid.Column="1"
                                    Text="Remove"
                                    Clicked="OnRemoveDishClicked"
                                    FontFamily="OpenSansSemibold"
                                    BackgroundColor="#F04438"
                                    TextColor="White"
                                    CornerRadius="18" />
                            <Button Grid.Column="2"
                                    Text="Edit"
                                    Clicked="OnEditDishClicked"
                                    FontFamily="OpenSansSemibold"
                                    BackgroundColor="#0F172A"
                                    TextColor="White"
                                    CornerRadius="18" />
                        </Grid>

                        <Border x:Name="DishEditorPanel"
                                BackgroundColor="#F8FAFC"
                                Stroke="#D8E2F0"
                                StrokeThickness="1"
                                Padding="16"
                                StrokeShape="RoundRectangle 20"
                                IsVisible="False">
                            <VerticalStackLayout Spacing="12">
                                <Label x:Name="DishEditorTitleLabel"
                                       Text="Add dish"
                                       FontFamily="MuseoModernoMedium"
                                       FontSize="18"
                                       TextColor="#111827" />
                                <Entry x:Name="DishNameEntry"
                                       Placeholder="Dish name"
                                       BackgroundColor="White"
                                       TextColor="#111827" />
                                <Editor x:Name="DishDescriptionEditor"
                                        Placeholder="Short description"
                                        AutoSize="TextChanges"
                                        BackgroundColor="White"
                                        TextColor="#111827"
                                        MinimumHeightRequest="80" />
                                <Grid ColumnDefinitions="*,*,*"
                                      ColumnSpacing="10">
                                    <Entry x:Name="ProteinEntry"
                                           Placeholder="Protein"
                                           Keyboard="Numeric"
                                           BackgroundColor="White"
                                           TextColor="#111827" />
                                    <Entry Grid.Column="1"
                                           x:Name="CarbsEntry"
                                           Placeholder="Carbs"
                                           Keyboard="Numeric"
                                           BackgroundColor="White"
                                           TextColor="#111827" />
                                    <Entry Grid.Column="2"
                                           x:Name="FatsEntry"
                                           Placeholder="Fats"
                                           Keyboard="Numeric"
                                           BackgroundColor="White"
                                           TextColor="#111827" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="10">
                                    <Button Text="Cancel"
                                            Clicked="OnCancelDishEditorClicked"
                                            FontFamily="OpenSansSemibold"
                                            BackgroundColor="#E5E7EB"
                                            TextColor="#111827"
                                            CornerRadius="18" />
                                    <Button Grid.Column="1"
                                            x:Name="DishSaveButton"
                                            Text="Save dish"
                                            Clicked="OnSaveDishClicked"
                                            FontFamily="OpenSansSemibold"
                                            BackgroundColor="#2B6DFF"
                                            TextColor="White"
                                            CornerRadius="18" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <CollectionView x:Name="DishesCollection"
                                        SelectionMode="Single"
                                        SelectionChanged="OnDishSelectionChanged">
                            <CollectionView.EmptyView>
                                <Border BackgroundColor="#F8FAFC"
                                        StrokeThickness="0"
                                        Padding="18"
                                        StrokeShape="RoundRectangle 18">
                                    <Label Text="No dishes yet. Add one to start filling the macro ring."
                                           FontFamily="OpenSansRegular"
                                           FontSize="14"
                                           TextColor="#667085" />
                                </Border>
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#F8FAFC"
                                            Stroke="#E5E7EB"
                                            StrokeThickness="1"
                                            Padding="14"
                                            Margin="0,0,0,10"
                                            StrokeShape="RoundRectangle 18">
                                        <VerticalStackLayout Spacing="8">
                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="10">
                                                <Label Text="{Binding Dishname}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="17"
                                                       TextColor="#111827" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding Protein, StringFormat='P {0}g'}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="13"
                                                       TextColor="#78D7B4" />
                                            </Grid>
                                            <Label Text="{Binding Description}"
                                                   FontFamily="OpenSansRegular"
                                                   FontSize="13"
                                                   TextColor="#667085" />
                                            <HorizontalStackLayout Spacing="10">
                                                <Label Text="{Binding Carbs, StringFormat='Carbs {0}g'}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="12"
                                                       TextColor="#2B6DFF" />
                                                <Label Text="{Binding Fats, StringFormat='Fats {0}g'}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="12"
                                                       TextColor="#F59E0B" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="White"
                        Stroke="#D8E2F0"
                        StrokeThickness="1"
                        Padding="18"
                        StrokeShape="RoundRectangle 24">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Goals"
                                   FontFamily="MuseoModernoBold"
                                   FontSize="22"
                                   TextColor="#111827" />
                            <Button Grid.Column="1"
                                    Text="+ Add"
                                    Clicked="OnAddGoalClicked"
                                    FontFamily="OpenSansSemibold"
                                    BackgroundColor="#2B6DFF"
                                    TextColor="White"
                                    CornerRadius="18" />
                        </Grid>

                        <Border x:Name="GoalEditorPanel"
                                BackgroundColor="#F8FAFC"
                                Stroke="#D8E2F0"
                                StrokeThickness="1"
                                Padding="16"
                                StrokeShape="RoundRectangle 20"
                                IsVisible="False">
                            <VerticalStackLayout Spacing="12">
                                <Label Text="Create goal node"
                                       FontFamily="MuseoModernoMedium"
                                       FontSize="18"
                                       TextColor="#111827" />
                                <Entry x:Name="GoalTitleEntry"
                                       Placeholder="Goal title"
                                       BackgroundColor="White"
                                       TextColor="#111827" />
                                <Editor x:Name="GoalDescriptionEditor"
                                        Placeholder="Goal description"
                                        AutoSize="TextChanges"
                                        BackgroundColor="White"
                                        TextColor="#111827"
                                        MinimumHeightRequest="80" />
                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="10">
                                    <DatePicker x:Name="GoalDatePicker"
                                                BackgroundColor="White"
                                                TextColor="#111827" />
                                    <Picker Grid.Column="1"
                                            x:Name="GoalSchedulePicker"
                                            Title="Schedule"
                                            BackgroundColor="White"
                                            TextColor="#111827" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="10">
                                    <Label Text="Recurring goal"
                                           VerticalOptions="Center"
                                           FontFamily="OpenSansRegular"
                                           FontSize="14"
                                           TextColor="#111827" />
                                    <CheckBox Grid.Column="1"
                                              x:Name="RecurringGoalCheckBox"
                                              Color="#2B6DFF" />
                                </Grid>
                                <VerticalStackLayout Spacing="4">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="Progress"
                                               FontFamily="OpenSansRegular"
                                               FontSize="14"
                                               TextColor="#111827" />
                                        <Label Grid.Column="1"
                                               x:Name="GoalProgressValueLabel"
                                               Text="0%"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="14"
                                               TextColor="#2B6DFF" />
                                    </Grid>
                                    <Slider x:Name="GoalProgressSlider"
                                            Minimum="0"
                                            Maximum="100"
                                            ValueChanged="OnGoalProgressChanged"
                                            MinimumTrackColor="#2B6DFF"
                                            MaximumTrackColor="#D0D5DD"
                                            ThumbColor="#2B6DFF" />
                                </VerticalStackLayout>
                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="10">
                                    <Button Text="Cancel"
                                            Clicked="OnCancelGoalEditorClicked"
                                            FontFamily="OpenSansSemibold"
                                            BackgroundColor="#E5E7EB"
                                            TextColor="#111827"
                                            CornerRadius="18" />
                                    <Button Grid.Column="1"
                                            Text="Save goal"
                                            Clicked="OnSaveGoalClicked"
                                            FontFamily="OpenSansSemibold"
                                            BackgroundColor="#111827"
                                            TextColor="White"
                                            CornerRadius="18" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <CollectionView x:Name="GoalsCollection"
                                        SelectionMode="None">
                            <CollectionView.EmptyView>
                                <Border BackgroundColor="#F8FAFC"
                                        StrokeThickness="0"
                                        Padding="18"
                                        StrokeShape="RoundRectangle 18">
                                    <Label Text="No goals yet. Create a daily, weekly, monthly, or yearly node."
                                           FontFamily="OpenSansRegular"
                                           FontSize="14"
                                           TextColor="#667085" />
                                </Border>
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#F8FAFC"
                                            Stroke="#E5E7EB"
                                            StrokeThickness="1"
                                            Padding="14"
                                            Margin="0,0,0,10"
                                            StrokeShape="RoundRectangle 18">
                                        <VerticalStackLayout Spacing="8">
                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="10">
                                                <Label Text="{Binding Header}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="17"
                                                       TextColor="#111827" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding ScheduleType}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="12"
                                                       TextColor="#2B6DFF" />
                                            </Grid>
                                            <Label Text="{Binding Description}"
                                                   FontFamily="OpenSansRegular"
                                                   FontSize="13"
                                                   TextColor="#667085" />
                                            <HorizontalStackLayout Spacing="10">
                                                <Label Text="{Binding FinishDate, StringFormat='Due {0:dd MMM yyyy}'}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="12"
                                                       TextColor="#475467" />
                                                <Label Text="{Binding IsRecurring, StringFormat='Recurring: {0}'}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="12"
                                                       TextColor="#475467" />
                                            </HorizontalStackLayout>
                                            <ProgressBar Progress="{Binding Progress}"
                                                         ProgressColor="#2B6DFF"
                                                         BackgroundColor="#D0D5DD"
                                                         HeightRequest="10" />
                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                  ColumnSpacing="10">
                                                <Label Text="{Binding Progress, StringFormat='{}{0:P0}'}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="12"
                                                       TextColor="#111827" />
                                                <Button Grid.Column="2"
                                                        Text="Delete"
                                                        Clicked="OnDeleteGoalClicked"
                                                        CommandParameter="{Binding Id}"
                                                        FontFamily="OpenSansSemibold"
                                                        BackgroundColor="#F04438"
                                                        TextColor="White"
                                                        CornerRadius="14"
                                                        Padding="12,6" />
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
