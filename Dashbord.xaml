<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppFitnessTrackerReal.Dashbord"
             BackgroundColor="Black"
             Title="">
    <ScrollView>
        <Grid HorizontalOptions="Center"
              VerticalOptions="Start"
              WidthRequest="420"
              MaximumWidthRequest="420"
              Padding="18,20,18,40"
              BackgroundColor="#FAF4E4">
            <VerticalStackLayout Spacing="18">
                <Grid ColumnDefinitions="Auto,* ,Auto"
                      VerticalOptions="Center">
                    <Border Grid.Column="0"
                            BackgroundColor="#2B6DFF"
                            StrokeThickness="0"
                            Padding="12"
                            StrokeShape="RoundRectangle 22">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAccountTapped" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="34,Auto"
                              ColumnSpacing="10">
                            <Grid WidthRequest="34"
                                  HeightRequest="34">
                                <Ellipse WidthRequest="13"
                                         HeightRequest="13"
                                         Fill="White"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Start"
                                         Margin="0,3,0,0" />
                                <Ellipse WidthRequest="20"
                                         HeightRequest="12"
                                         Fill="White"
                                         HorizontalOptions="Center"
                                         VerticalOptions="End"
                                         Margin="0,0,0,2" />
                            </Grid>
                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="0"
                                                 VerticalOptions="Center">
                                <Label Text="Konto"
                                       FontFamily="OpenSansRegular"
                                       FontSize="12"
                                       TextColor="#D8E5FF" />
                                <Label x:Name="UserNameLabel"
                                       Text="Gosc"
                                       FontFamily="MuseoModernoMedium"
                                       FontSize="15"
                                       TextColor="White" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <Button Grid.Column="2"
                            Text="Wyloguj"
                            Clicked="OnLogoutClicked"
                            FontFamily="OpenSansSemibold"
                            BackgroundColor="#111827"
                            TextColor="White"
                            CornerRadius="18"
                            Padding="18,12" />
                </Grid>

                <Border BackgroundColor="#FAF4E4"
                         Stroke="Black"
                         StrokeThickness="1"
                         Padding="18"
                         StrokeShape="RoundRectangle 24"
                        >
                    <VerticalStackLayout Spacing="18"
                                        >
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Bilans odzywiania"
                                   FontFamily="MuseoModernoBold"
                                   FontSize="24"
                                   TextColor="Black" />
                         
                          
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,Auto"
                              ColumnSpacing="10">
                            <Entry x:Name="DailyCaloriesGoalEntry"
                                   Placeholder="Dzienny cel kcal"
                                   Keyboard="Numeric"
                                   BackgroundColor="#16233C"
                                   TextColor="White"
                                   PlaceholderColor="#9FB0CF" />
                            <Button Grid.Column="1"
                                    Text="Ustaw"
                                    Clicked="OnSaveCalorieGoalClicked"
                                    FontFamily="OpenSansSemibold"
                                    BackgroundColor="#2B6DFF"
                                    TextColor="White"
                                    CornerRadius="18"
                                    Padding="16,10" />
                        </Grid>

                        <Grid HorizontalOptions="Center"
                              WidthRequest="270"
                              HeightRequest="270">
                            <GraphicsView x:Name="MacroRingView"
                                          HeightRequest="270"
                                          WidthRequest="270" />
                            <VerticalStackLayout HorizontalOptions="Center"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label Text="Kalorie"
                                       HorizontalTextAlignment="Center"
                                       FontFamily="OpenSansRegular"
                                       FontSize="13"
                                       TextColor="Black" />
                                <Label x:Name="MacroTotalLabel"
                                       Text="0 / 2000 kcal"
                                       HorizontalTextAlignment="Center"
                                       FontFamily="MuseoModernoBold"
                                       FontSize="24"
                                       TextColor="Black" />
                            </VerticalStackLayout>
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*"
                              ColumnSpacing="10">
                            <Border BackgroundColor="#16233C"
                                    StrokeThickness="0"
                                    Padding="12"
                                    StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="Bialko"
                                           FontFamily="OpenSansRegular"
                                           FontSize="12"
                                           TextColor="#9FB0CF" />
                                    <Label x:Name="ProteinValueLabel"
                                           Text="0 g"
                                           FontFamily="MuseoModernoMedium"
                                           FontSize="20"
                                           TextColor="#78D7B4" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1"
                                    BackgroundColor="#16233C"
                                    StrokeThickness="0"
                                    Padding="12"
                                    StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="Wegle"
                                           FontFamily="OpenSansRegular"
                                           FontSize="12"
                                           TextColor="#9FB0CF" />
                                    <Label x:Name="CarbsValueLabel"
                                           Text="0 g"
                                           FontFamily="MuseoModernoMedium"
                                           FontSize="20"
                                           TextColor="#6AA7FF" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="2"
                                    BackgroundColor="#16233C"
                                    StrokeThickness="0"
                                    Padding="12"
                                    StrokeShape="RoundRectangle 18">
                                <VerticalStackLayout Spacing="3">
                                    <Label Text="Tluszcze"
                                           FontFamily="OpenSansRegular"
                                           FontSize="12"
                                           TextColor="#9FB0CF" />
                                    <Label x:Name="FatsValueLabel"
                                           Text="0 g"
                                           FontFamily="MuseoModernoMedium"
                                           FontSize="20"
                                           TextColor="#FFB45C" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#FAF4E4"
                        Stroke="Black"
                        StrokeThickness="1"
                        Padding="18"
                        StrokeShape="RoundRectangle 24">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="3">
                                <Label Text="Menedzer posilkow"
                                       FontFamily="MuseoModernoBold"
                                       FontSize="22"
                                       TextColor="#111827" />
                                
                            </VerticalStackLayout>
                         
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*"
                              ColumnSpacing="10">
                            <Button Grid.Column="0"
                                    Text="Dodaj"
                                    Clicked="OnAddDishClicked"
                                    FontFamily="OpenSansSemibold"
                                    BackgroundColor="#2B6DFF"
                                    TextColor="White"
                                    CornerRadius="18" />
                            <Button Grid.Column="1"
                                    Text="Usun"
                                    Clicked="OnRemoveDishClicked"
                                    FontFamily="OpenSansSemibold"
                                    BackgroundColor="#F04438"
                                    TextColor="White"
                                    CornerRadius="18" />
                            <Button Grid.Column="2"
                                    Text="Edytuj"
                                    Clicked="OnEditDishClicked"
                                    FontFamily="OpenSansSemibold"
                                    BackgroundColor="#0F172A"
                                    TextColor="White"
                                    CornerRadius="18" />
                        </Grid>

                        <Border x:Name="DishEditorPanel"
                                BackgroundColor="#F8FAFC"
                                Stroke="#D8E2F0"
                                StrokeThickness="1"
                                Padding="16"
                                StrokeShape="RoundRectangle 20"
                                IsVisible="False">
                            <VerticalStackLayout Spacing="12">
                                <Label x:Name="DishEditorTitleLabel"
                                       Text="Dodaj posilek"
                                       FontFamily="MuseoModernoMedium"
                                       FontSize="18"
                                       TextColor="#111827" />
                                <Entry x:Name="DishNameEntry"
                                       Placeholder="Nazwa posilku"
                                       BackgroundColor="White"
                                       TextColor="#111827" />
                                <Editor x:Name="DishDescriptionEditor"
                                        Placeholder="Krotki opis"
                                        AutoSize="TextChanges"
                                        BackgroundColor="White"
                                        TextColor="#111827"
                                        MinimumHeightRequest="80" />
                                <Grid ColumnDefinitions="*,*,*,*"
                                      ColumnSpacing="8">
                                    <Entry x:Name="ProteinEntry"
                                           Placeholder="Bialko"
                                           Keyboard="Numeric"
                                           BackgroundColor="White"
                                           TextColor="#111827" />
                                    <Entry Grid.Column="1"
                                           x:Name="CarbsEntry"
                                           Placeholder="Wegle"
                                           Keyboard="Numeric"
                                           BackgroundColor="White"
                                           TextColor="#111827" />
                                    <Entry Grid.Column="2"
                                           x:Name="FatsEntry"
                                           Placeholder="Tluszcze"
                                           Keyboard="Numeric"
                                           BackgroundColor="White"
                                           TextColor="#111827" />
                                    <Entry Grid.Column="3"
                                           x:Name="CaloriesEntry"
                                           Placeholder="Kcal"
                                           Keyboard="Numeric"
                                           BackgroundColor="White"
                                           TextColor="#111827" />
                                </Grid>
                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="10">
                                    <Button Text="Anuluj"
                                            Clicked="OnCancelDishEditorClicked"
                                            FontFamily="OpenSansSemibold"
                                            BackgroundColor="#E5E7EB"
                                            TextColor="#111827"
                                            CornerRadius="18" />
                                    <Button Grid.Column="1"
                                            x:Name="DishSaveButton"
                                            Text="Zapisz posilek"
                                            Clicked="OnSaveDishClicked"
                                            FontFamily="OpenSansSemibold"
                                            BackgroundColor="#2B6DFF"
                                            TextColor="White"
                                            CornerRadius="18" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <CollectionView x:Name="DishesCollection"
                                        SelectionMode="Single"
                                        SelectionChanged="OnDishSelectionChanged">
                            <CollectionView.EmptyView>
                                <Border BackgroundColor="#F8FAFC"
                                        StrokeThickness="0"
                                        Padding="18"
                                        StrokeShape="RoundRectangle 18">
                                    <Label Text="Nie ma jeszcze posilkow. Dodaj pierwszy, aby wypelnic pierscien makro."
                                           FontFamily="OpenSansRegular"
                                           FontSize="14"
                                           TextColor="#667085" />
                                </Border>
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#F8FAFC"
                                            Stroke="#E5E7EB"
                                            StrokeThickness="1"
                                            Padding="14"
                                            Margin="0,0,0,10"
                                            StrokeShape="RoundRectangle 18">
                                        <VerticalStackLayout Spacing="8">
                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="10">
                                                <Label Text="{Binding Dishname}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="17"
                                                       TextColor="#111827" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding Calories, StringFormat='{0} kcal'}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="13"
                                                       TextColor="#F04438" />
                                            </Grid>
                                            <Label Text="{Binding Description}"
                                                   FontFamily="OpenSansRegular"
                                                   FontSize="13"
                                                   TextColor="#667085" />
                                            <HorizontalStackLayout Spacing="10">
                                                <Label Text="{Binding Carbs, StringFormat='Wegle {0} g'}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="12"
                                                       TextColor="#2B6DFF" />
                                                <Label Text="{Binding Fats, StringFormat='Tluszcze {0} g'}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="12"
                                                       TextColor="#F59E0B" />
                                                <Label Text="{Binding Protein, StringFormat='Bialko {0} g'}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="12"
                                                       TextColor="#78D7B4" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="#FAF4E4"
                        Stroke="#333"
                        StrokeThickness="1"
                        Padding="18"
                        StrokeShape="RoundRectangle 24">
                    <VerticalStackLayout Spacing="14">
                        <Grid ColumnDefinitions="*,*,Auto">
                            <Label Text="Cele"
                                   FontFamily="MuseoModernoBold"
                                   FontSize="22"
                                   TextColor="#111827" />
                            <Button Grid.Column="1"
                                      Text="Edytuj"
                                      Clicked="OnEditGoalClicked"
                                      FontFamily="OpenSansSemibold"
                                      BackgroundColor="#0F172A"
                                      TextColor="White"
                                      CornerRadius="14"
                                      Margin="0,2,17,3" /> 
                            <Button Grid.Column="2"
                                    Text="+ Dodaj"
                                    Clicked="OnAddGoalClicked"
                                    FontFamily="OpenSansSemibold"
                                    BackgroundColor="#2B6DFF"
                                    TextColor="White"
                                    CornerRadius="18" />

                        
                        </Grid>

                        <Border x:Name="GoalEditorPanel"
                                BackgroundColor="White"
                                Stroke="#D8E2F0"
                                StrokeThickness="1"
                                Padding="16"
                                StrokeShape="RoundRectangle 20"
                                IsVisible="False">
                            <VerticalStackLayout Spacing="12">
                                <Label Text="Utworz cel"
                                       FontFamily="MuseoModernoMedium"
                                       FontSize="18"
                                       TextColor="#111827" />
                                <Entry x:Name="GoalTitleEntry"
                                       Placeholder="Tytul celu"
                                       BackgroundColor="White"
                                       TextColor="#111827" />
                                <Editor x:Name="GoalDescriptionEditor"
                                        Placeholder="Opis celu"
                                        AutoSize="TextChanges"
                                        BackgroundColor="White"
                                        TextColor="#111827"
                                        MinimumHeightRequest="80" />
                                <Grid ColumnDefinitions="*,*" 
                                      ColumnSpacing="10"
                                      RowDefinitions="*,*">
                                    <Label Text="Termin realizacji"
                                           VerticalOptions="Center"
                                           FontFamily="OpenSansRegular"
                                           FontSize="14"
                                           TextColor="#d1d1d1"
                                           Grid.Row="0"/>
                                        <DatePicker x:Name="GoalDatePicker"
                                                BackgroundColor="White"
                                                TextColor="#111827"
                                                    Grid.Row="1"
                                                 />
                                    <Label Text="Harmonogram"
                                           VerticalOptions="Center"
                                           FontFamily="OpenSansRegular"
                                           FontSize="14"
                                           TextColor="#d1d1d1"
                                           Grid.Row="0"
                                           Grid.Column="1"/>       
                                    <Picker Grid.Column="1"
                                            x:Name="GoalSchedulePicker"
                                        
                                            BackgroundColor="White"
                                            TextColor="#111827" Grid.Row="1" />
                                </Grid>
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="10">
                                    <Label Text="Cel powtarzalny"
                                           VerticalOptions="Center"
                                           FontFamily="OpenSansRegular"
                                           FontSize="14"
                                           TextColor="#111827" />
                                    <CheckBox Grid.Column="1"
                                              x:Name="RecurringGoalCheckBox"
                                              Color="#2B6DFF" />
                                </Grid>
                                <VerticalStackLayout Spacing="4">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="Postep"
                                               FontFamily="OpenSansRegular"
                                               FontSize="14"
                                               TextColor="#111827" />
                                        <Label Grid.Column="1"
                                               x:Name="GoalProgressValueLabel"
                                               Text="0%"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="14"
                                               TextColor="#2B6DFF" />
                                    </Grid>
                                    <Slider x:Name="GoalProgressSlider"
                                            Minimum="0"
                                            Maximum="100"
                                            ValueChanged="OnGoalProgressChanged"
                                            MinimumTrackColor="#2B6DFF"
                                            MaximumTrackColor="#D0D5DD"
                                            ThumbColor="#2B6DFF" />
                                </VerticalStackLayout>
                                <Grid ColumnDefinitions="*,*"
                                      ColumnSpacing="10">
                                    <Button Text="Anuluj"
                                            Clicked="OnCancelGoalEditorClicked"
                                            FontFamily="OpenSansSemibold"
                                            BackgroundColor="#E5E7EB"
                                            TextColor="#111827"
                                            CornerRadius="18" />
                                    <Button Grid.Column="1"
                                            Text="Zapisz cel"
                                            Clicked="OnSaveGoalClicked"
                                            FontFamily="OpenSansSemibold"
                                            BackgroundColor="#111827"
                                            TextColor="White"
                                            CornerRadius="18" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <CollectionView x:Name="GoalsCollection"
                                        SelectionMode="Single"
                                        SelectionChanged="OnGoalSelectionChanged">  
                            <CollectionView.EmptyView>
                                <Border BackgroundColor="#F8FAFC"
                                        StrokeThickness="0"
                                        Padding="18"
                                        StrokeShape="RoundRectangle 18">
                                    <Label Text="Nie ma jeszcze celow. Utworz cel dzienny, tygodniowy, miesieczny lub roczny."
                                           FontFamily="OpenSansRegular"
                                           FontSize="14"
                                           TextColor="#667085" />
                                </Border>
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#F8FAFC"
                                            Stroke="#E5E7EB"
                                            StrokeThickness="1"
                                            Padding="14"
                                            Margin="0,0,0,10"
                                            StrokeShape="RoundRectangle 18">
                                        <VerticalStackLayout Spacing="8">
                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="10">
                                                <Label Text="{Binding Header}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="17"
                                                       TextColor="#111827" />
                                                <Label Grid.Column="1"
                                                       Text="{Binding ScheduleType}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="12"
                                                       TextColor="#2B6DFF" />
                                            </Grid>
                                            <Label Text="{Binding Description}"
                                                   FontFamily="OpenSansRegular"
                                                   FontSize="13"
                                                   TextColor="#667085" />
                                            <HorizontalStackLayout Spacing="10">
                                                <Label Text="{Binding FinishDate, StringFormat='Termin do {0:dd MMM yyyy}'}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="12"
                                                       TextColor="#475467" />
                                                <Label Text="{Binding RecurringText, StringFormat='Powtarzalny: {0}'}"
                                                       FontFamily="OpenSansRegular"
                                                       FontSize="12"
                                                       TextColor="#475467" />
                                            </HorizontalStackLayout>
                                            <ProgressBar Progress="{Binding Progress}"
                                                         ProgressColor="#2B6DFF"
                                                         BackgroundColor="#D0D5DD"
                                                         HeightRequest="10" />
                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                  ColumnSpacing="10">
                                                <Label Text="{Binding Progress, StringFormat='{}{0:P0}'}"
                                                       FontFamily="OpenSansSemibold"
                                                       FontSize="12"
                                                       TextColor="#111827" />
                                                <Button Grid.Column="2"
                                                        Text="Usun"
                                                        Clicked="OnDeleteGoalClicked"
                                                        CommandParameter="{Binding Id}"
                                                        FontFamily="OpenSansSemibold"
                                                        BackgroundColor="#F04438"
                                                        TextColor="White"
                                                        CornerRadius="14"
                                                        Padding="12,6" />
                                          
                                            </Grid>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
